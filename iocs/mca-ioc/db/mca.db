# mca.db -- one mcaRecord instance bound to an asynMCA driver (devMcaAsyn).
#
# Macros:
#   P, R      - record name prefix/suffix -> "$(P)$(R)"
#   PORT      - the asyn MCA port name (e.g. an initFastSweep portName)
#   ADDR      - asyn address selecting which signal's spectrum this record
#               reads (default 0)
#   NCHAN     - NMAX/NUSE, the record's channel-array capacity; must match
#               the driver's own maxPoints (FastSweepConfig's maxPoints)

grecord(mca,"$(P)$(R)") {
	field(DTYP,"asynMCA")
	field(INP,"@asyn($(PORT),$(ADDR=0))")
	field(NMAX,"$(NCHAN)")
	field(NUSE,"$(NCHAN)")
}
