# Aerotech A3200: one motor record per axis. Load once per axis, matching an
# axis discovered by A3200AsynConfig. DTYP is A3200_$(CTRL)_$(AXISNAME), where
# AXISNAME is the controller's axis name string (e.g. X, Y, Z).
#
# The driver works in the A3200's user units (the C stepSize = 1/CountsPerUnit
# scaling cancels at the EGU boundary), so MRES = 1 and EGU is whatever the
# controller's CountsPerUnit is configured for (e.g. mm or deg). VELO/ACCL are in
# those user units per second / per second^2.

record(motor, "$(P)$(M)") {
    field(DTYP, "A3200_$(CTRL)_$(AXISNAME)")
    field(SCAN, "Passive")
    field(VELO, "$(VELO=10.0)")
    field(ACCL, "$(ACCL=0.2)")
    field(DHLM, "$(HLM=100.0)")
    field(DLLM, "$(LLM=-100.0)")
    field(MRES, "$(MRES=1.0)")
    field(EGU,  "$(EGU=mm)")
    field(PREC, "$(PREC=4)")
}
