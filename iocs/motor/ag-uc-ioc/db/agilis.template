# Newport Agilis AG-UC: one motor record per axis. The Agilis is an open-loop
# stepper (no encoder), so positions are raw accumulated steps — MRES = 1.

record(motor, "$(P)$(M0)") {
    field(DTYP, "AG_UC_$(PORT)_0")
    field(SCAN, "Passive")
    field(VELO, "$(VELO=100.0)")
    field(ACCL, "$(ACCL=0.5)")
    field(DHLM, "$(HLM=100000)")
    field(DLLM, "$(LLM=-100000)")
    field(MRES, "$(MRES=1)")
    field(EGU,  "$(EGU=steps)")
    field(PREC, "$(PREC=0)")
}

record(motor, "$(P)$(M1)") {
    field(DTYP, "AG_UC_$(PORT)_1")
    field(SCAN, "Passive")
    field(VELO, "$(VELO=100.0)")
    field(ACCL, "$(ACCL=0.5)")
    field(DHLM, "$(HLM=100000)")
    field(DLLM, "$(LLM=-100000)")
    field(MRES, "$(MRES=1)")
    field(EGU,  "$(EGU=steps)")
    field(PREC, "$(PREC=0)")
}
