# piezosystem jena E-516 (PIJEDS): one motor record per axis. Load once per
# axis with N = 0-based axis index (DTYP PIJEDS_$(CARD)_$(N)); the driver maps
# index 0,1,2,... to controller axes 0,1,2,...
#
# The E-516 is a CLOSED-LOOP capacitive-feedback piezo positioner. Positions
# travel the driver boundary in physical units (µm); MRES = drive_resolution
# (1e-3 = 1/10^3) sets the record's raw-count resolution and EGU is um. Motion
# completion is inferred from the feedback position settling. Homing and
# hardware limit switches are not supported; VELO maps to the controller's slew
# rate.

record(motor, "$(P)$(M)") {
    field(DTYP, "PIJEDS_$(CARD)_$(N)")
    field(SCAN, "Passive")
    field(VELO, "$(VELO=10.0)")
    field(ACCL, "$(ACCL=0.5)")
    field(DHLM, "$(HLM=100.0)")
    field(DLLM, "$(LLM=0.0)")
    field(MRES, "$(MRES=1.0e-3)")
    field(EGU,  "$(EGU=um)")
    field(PREC, "$(PREC=3)")
}
