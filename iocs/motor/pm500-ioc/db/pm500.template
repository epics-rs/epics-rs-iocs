# Newport PM500: one motor record per axis. Load once per axis with
# N = 0-based axis index (DTYP PM500_$(PORT)_$(N)); the driver maps index
# 0,1,2,... to controller channels X,Y,Z,A,...
# Positions travel the driver boundary in EGU (controller units: microns or
# arc-sec) directly; MRES only sets the record's raw-count resolution
# (display/deadband granularity). Velocities are EGU/sec — the driver
# performs the wire's um/s -> mm/s conversion itself.

record(motor, "$(P)$(M)") {
    field(DTYP, "PM500_$(PORT)_$(N)")
    field(SCAN, "Passive")
    field(VELO, "$(VELO=100.0)")
    field(ACCL, "$(ACCL=0.5)")
    field(DHLM, "$(HLM=10000.0)")
    field(DLLM, "$(LLM=-10000.0)")
    field(MRES, "$(MRES=0.01)")
    field(EGU,  "$(EGU=um)")
    field(PREC, "$(PREC=3)")
}
