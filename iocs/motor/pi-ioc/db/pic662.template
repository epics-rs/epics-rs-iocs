# PI E-662: one motor record for the controller's single axis. DTYP is
# PIC662_$(CARD)_0 (the fixed axis-0 key registered by PIC662Config — the
# E-662 is a single-axis piezo controller).
#
# The record works in raw counts (the driver scales to/from micrometres by the
# fixed drive resolution 0.001 at the wire), so MRES = 1 and EGU = counts. The
# E-662 has no velocity/accel/jog/home wire commands; only absolute and
# relative moves reach the controller.

record(motor, "$(P)$(M)") {
    field(DTYP, "PIC662_$(CARD)_0")
    field(SCAN, "Passive")
    field(VELO, "$(VELO=1000.0)")
    field(ACCL, "$(ACCL=0.2)")
    field(DHLM, "$(HLM=100000.0)")
    field(DLLM, "$(LLM=-100000.0)")
    field(MRES, "$(MRES=1.0)")
    field(EGU,  "$(EGU=counts)")
    field(PREC, "$(PREC=0)")
}
