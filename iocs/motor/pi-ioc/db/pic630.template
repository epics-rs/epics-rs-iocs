# PI C-630: one motor record per daisy-chained axis. DTYP is
# PIC630_$(CARD)_$(AXIS) (the per-axis key registered by PIC630Config; wire
# address is $(AXIS)+1, i.e. 1-9). Load this template once per axis with a
# distinct AXIS/M.
#
# The C-630 works in raw controller counts (MA/MR/TP are integer counts, no
# separate EGU scaling in the driver), so MRES = 1 and EGU = counts.

record(motor, "$(P)$(M)") {
    field(DTYP, "PIC630_$(CARD)_$(AXIS)")
    field(SCAN, "Passive")
    field(VELO, "$(VELO=1000.0)")
    field(ACCL, "$(ACCL=0.2)")
    field(DHLM, "$(HLM=1000000.0)")
    field(DLLM, "$(LLM=-1000000.0)")
    field(MRES, "$(MRES=1.0)")
    field(EGU,  "$(EGU=counts)")
    field(PREC, "$(PREC=0)")
}
