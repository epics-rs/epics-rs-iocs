# PI C-663: one motor record for the controller's single axis. DTYP is
# PIC663_$(CARD)_0 (the fixed axis-0 key registered by PIC663Config — the
# C-663 has exactly one axis per controller, same as the C-862 it clones).
#
# The C-663 works in raw controller counts (MA/MR/TP are integer counts, no
# separate EGU scaling in the driver), so MRES = 1 and EGU = counts.

record(motor, "$(P)$(M)") {
    field(DTYP, "PIC663_$(CARD)_0")
    field(SCAN, "Passive")
    field(VELO, "$(VELO=1000.0)")
    field(ACCL, "$(ACCL=0.2)")
    field(DHLM, "$(HLM=1000000.0)")
    field(DLLM, "$(LLM=-1000000.0)")
    field(MRES, "$(MRES=1.0)")
    field(EGU,  "$(EGU=counts)")
    field(PREC, "$(PREC=0)")
}
