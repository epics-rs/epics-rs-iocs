# PI E-516: one motor record per axis. DTYP is PIE516_$(CARD)_$(AXIS) — the
# per-axis key registered by PIE516Config (axis 0/1/2 = letters A/B/C, in the
# order they responded to the connect-time POS? probe).
#
# The E-516 driver works in POS_RES-sized steps (1 step = 0.001 um; the driver
# multiplies outgoing positions by POS_RES and divides POS? micrometres back by
# it), so MRES = 1 and EGU is steps. The E-516 is a closed-loop piezo (NTM=No,
# no home, no set-position).

record(motor, "$(P)$(M)") {
    field(DTYP, "PIE516_$(CARD)_$(AXIS=0)")
    field(SCAN, "Passive")
    field(VELO, "$(VELO=1000.0)")
    field(ACCL, "$(ACCL=0.2)")
    field(DHLM, "$(HLM=1000000.0)")
    field(DLLM, "$(LLM=-1000000.0)")
    field(MRES, "$(MRES=1.0)")
    field(EGU,  "$(EGU=steps)")
    field(PREC, "$(PREC=0)")
}
