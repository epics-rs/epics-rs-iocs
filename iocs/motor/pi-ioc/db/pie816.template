# PI E-816: one motor record per axis. DTYP is PIE816_$(CARD)_$(AXIS) — the
# per-axis key registered by PIE816Config (axis 0..11 = command letters A..L,
# in the order they responded to the connect-time POS? probe).
#
# The driver works in POS_RES-sized steps (1 step = 0.0001 um), so MRES = 1 and
# EGU is steps. Closed-loop piezo (NTM=No, no home, no set-position; stop is a
# zero relative move).

record(motor, "$(P)$(M)") {
    field(DTYP, "PIE816_$(CARD)_$(AXIS=0)")
    field(SCAN, "Passive")
    field(VELO, "$(VELO=1000.0)")
    field(ACCL, "$(ACCL=0.2)")
    field(DHLM, "$(HLM=1000000.0)")
    field(DLLM, "$(LLM=-1000000.0)")
    field(MRES, "$(MRES=1.0)")
    field(EGU,  "$(EGU=steps)")
    field(PREC, "$(PREC=0)")
}
