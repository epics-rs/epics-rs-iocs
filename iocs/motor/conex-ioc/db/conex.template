record(motor, "$(P)$(M)") {
    field(DTYP, "CONEX_$(PORT)")
    field(SCAN, "Passive")
    field(VELO, "$(VELO=1.0)")
    field(ACCL, "$(ACCL=0.5)")
    field(DHLM, "$(HLM=100.0)")
    field(DLLM, "$(LLM=-100.0)")
    # MRES (EGU per step) must match the driver's runtime stepSize for the
    # controller/stage. Default 1e-4 suits the DL model; CC/AGP use the stage
    # encoder increment, CONEX-PP uses fullStepSize/microSteps.
    field(MRES, "$(MRES=0.0001)")
    field(EGU,  "$(EGU=mm)")
    field(PREC, "$(PREC=4)")
}
