record(motor, "$(P)$(M)") {
    field(DTYP, "CONEX_$(PORT)")
    field(SCAN, "Passive")
    field(VELO, "$(VELO=1.0)")
    field(ACCL, "$(ACCL=0.5)")
    field(DHLM, "$(HLM=100.0)")
    field(DLLM, "$(LLM=-100.0)")
    # Positions travel the driver boundary in EGU (controller units, mm)
    # directly; MRES only sets the record's raw-count resolution
    # (display/deadband granularity).
    field(MRES, "$(MRES=0.0001)")
    field(EGU,  "$(EGU=mm)")
    field(PREC, "$(PREC=4)")
}
