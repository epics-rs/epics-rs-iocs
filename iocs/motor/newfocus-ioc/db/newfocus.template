# Newport New Focus PMNC 8750/8752: one motor record per discovered channel.
# Load once per axis with N = 0-based discovery index (DTYP PMNC_$(PORT)_$(N));
# the driver maps the index onto the discovered (driver module, channel).
# Picomotor moves are integer steps: positions travel the driver boundary in
# EGU (= steps), so MRES=1 (EGU identical to raw counts). Velocity is
# steps/sec (clamped to 2000), acceleration steps/sec^2 (clamped 16..32000).

record(motor, "$(P)$(M)") {
    field(DTYP, "PMNC_$(PORT)_$(N)")
    field(SCAN, "Passive")
    field(VELO, "$(VELO=1000)")
    field(ACCL, "$(ACCL=0.5)")
    field(DHLM, "$(HLM=1000000)")
    field(DLLM, "$(LLM=-1000000)")
    field(MRES, "$(MRES=1)")
    field(EGU,  "$(EGU=steps)")
    field(PREC, "$(PREC=0)")
}
