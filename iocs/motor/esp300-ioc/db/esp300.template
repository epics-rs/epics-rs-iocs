# Newport ESP100/ESP300/ESP301: one motor record per axis. Load once per
# discovered axis with N = 0-based axis index (DTYP ESP300_$(PORT)_$(N)).
# MRES must be the axis drive resolution (motorNewport README: "User must set
# MRES to drive resolution"): the driver reads back positions in
# drive-resolution steps, so MRES converts them to engineering units.

record(motor, "$(P)$(M)") {
    field(DTYP, "ESP300_$(PORT)_$(N)")
    field(SCAN, "Passive")
    field(VELO, "$(VELO=1.0)")
    field(ACCL, "$(ACCL=0.5)")
    field(DHLM, "$(HLM=100.0)")
    field(DLLM, "$(LLM=-100.0)")
    field(MRES, "$(MRES=0.0001)")
    field(EGU,  "$(EGU=mm)")
    field(PREC, "$(PREC=4)")
}
