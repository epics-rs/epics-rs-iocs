# Newport ESP100/ESP300/ESP301: one motor record per axis. Load once per
# discovered axis with N = 0-based axis index (DTYP ESP300_$(PORT)_$(N)).
# Positions travel the driver boundary in EGU (controller units, mm/deg per
# the stage SN configuration) directly; MRES only sets the record's raw-count
# resolution (display/deadband granularity). The motorNewport README's "set
# MRES to drive resolution" rule applied to the C raw-step boundary only.

record(motor, "$(P)$(M)") {
    field(DTYP, "ESP300_$(PORT)_$(N)")
    field(SCAN, "Passive")
    field(VELO, "$(VELO=1.0)")
    field(ACCL, "$(ACCL=0.5)")
    field(DHLM, "$(HLM=100.0)")
    field(DLLM, "$(LLM=-100.0)")
    field(MRES, "$(MRES=0.0001)")
    field(EGU,  "$(EGU=mm)")
    field(PREC, "$(PREC=4)")
}
