# Newport HXP hexapod: one motor record per hexapod coordinate.
# X/Y/Z are translations (mm), U/V/W rotations (deg). The driver hardcodes
# MRES = 0.00001 device units per step (C HXPDriver MRES), so the records use
# the same value and RBV reads back in engineering units.

record(motor, "$(P)$(MX)") {
    field(DTYP, "HXP_$(PORT)_0")
    field(SCAN, "Passive")
    field(DHLM, "$(HLM=50)")
    field(DLLM, "$(LLM=-50)")
    field(MRES, "$(MRES=0.00001)")
    field(EGU,  "mm")
    field(PREC, "$(PREC=5)")
}

