# Newport HXP hexapod: one motor record per hexapod coordinate.
# X/Y/Z are translations (mm), U/V/W rotations (deg). Positions travel the
# driver boundary in engineering units (mm/deg) directly; MRES only sets the
# record's raw-count resolution (display/deadband granularity). 0.00001
# matches the C HXPDriver's hardcoded record MRES.

record(motor, "$(P)$(MX)") {
    field(DTYP, "HXP_$(PORT)_0")
    field(SCAN, "Passive")
    field(DHLM, "$(HLM=50)")
    field(DLLM, "$(LLM=-50)")
    field(MRES, "$(MRES=0.00001)")
    field(EGU,  "mm")
    field(PREC, "$(PREC=5)")
}

