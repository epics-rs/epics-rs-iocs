# Newport XPS: one motor record per axis. The XPS is a closed-loop servo with
# an encoder, so RBV tracks the encoder position. Positions are in engineering
# units (mm/deg); pass stepsPerUnit=1 in XPSCreateAxis so positions travel the
# driver boundary in EGU unscaled. MRES only sets the record's raw-count
# resolution (display/deadband granularity).

record(motor, "$(P)$(M0)") {
    field(DTYP, "XPS_$(PORT)_0")
    field(SCAN, "Passive")
    field(VELO, "$(VELO=10.0)")
    field(ACCL, "$(ACCL=0.5)")
    field(DHLM, "$(HLM=100)")
    field(DLLM, "$(LLM=-100)")
    field(MRES, "$(MRES=1)")
    field(EGU,  "$(EGU=mm)")
    field(PREC, "$(PREC=4)")
}
