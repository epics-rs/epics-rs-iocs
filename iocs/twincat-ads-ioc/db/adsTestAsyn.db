###############################################################################
# The AMS port's own ADS state: 5 = RUN, 6 = STOP. Writing it commands the
# runtime; this is the driver's own datum, never read from the PLC's symbols.

record(ai,"$(P)GetAmsPort851State"){
    field(PINI, "1")
    field(DTYP, "asynInt32")
    field(INP,  "@asyn($(PORT),0,1)ADSPORT=$(ADSPORT=851)/.AMSPORTSTATE.?")
    field(SCAN, "I/O Intr")
}

record(ao,"$(P)SetAmsPort851State"){
    field(DTYP, "asynInt32")
    field(OUT,  "@asyn($(PORT),0,1)ADSPORT=$(ADSPORT=851)/.AMSPORTSTATE.?")
    field(SCAN, "Passive")

    info(asyn:READBACK,"1")
}
