# MPC / Digitel ion-pump controller. Port of ipApp/Db/MPC.db.
#
#   $(P)     PV prefix, e.g. "13IDA:"
#   $(PUMP)  this pump's name, e.g. "ip1"
#   $(PORT)  asyn port created by MPCConfig
#   $(PN)    supply (pump) number, 1 or 2 -> asyn address 0 or 1
#
# The controller address ($(PA) in the C database) moved into MPCConfig: it
# belongs to the port, not to each record.
#
# The C device support wrote the units the controller reported into each ai
# record's EGU field. A port driver cannot write EGU, so the units are published
# as their own stringin records (:PRES.EGU stays static, :PRESEGU carries what
# the controller said).

record(stringin, "$(P)$(PUMP):STAT") {
    field(DESC, "Pump status")
    field(SCAN, "I/O Intr")
    field(DTYP, "asynOctetRead")
    field(INP,  "@asyn($(PORT),$(ADDR=0),$(TIMEOUT=3))MPC_STATUS")
}

record(ai, "$(P)$(PUMP):PRES") {
    field(DESC, "Pressure")
    field(SCAN, "I/O Intr")
    field(DTYP, "asynFloat64")
    field(PREC, "1")
    field(INP,  "@asyn($(PORT),$(ADDR=0),$(TIMEOUT=3))MPC_PRESSURE")
}

record(stringin, "$(P)$(PUMP):PRESEGU") {
    field(DESC, "Pressure units reported")
    field(SCAN, "I/O Intr")
    field(DTYP, "asynOctetRead")
    field(INP,  "@asyn($(PORT),$(ADDR=0),$(TIMEOUT=3))MPC_PRESSURE_EGU")
}

record(ai, "$(P)$(PUMP):CUR") {
    field(DESC, "Pump current")
    field(SCAN, "I/O Intr")
    field(DTYP, "asynFloat64")
    field(PREC, "1")
    field(EGU,  "AMPS")
    field(INP,  "@asyn($(PORT),$(ADDR=0),$(TIMEOUT=3))MPC_CURRENT")
}

