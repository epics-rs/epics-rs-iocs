# vs record — vacuum gauge controller, devVacSen (asyn VacSen) device support.
#
# The asyn octet link lives in INP: "@asyn(PORT ADDR)STN". EOS is owned by the
# startup script (see the per-device asynOctetSet{Input,Output}Eos calls), not
# by the device support.
#
# Macros:
#   P     record prefix
#   GAUGE record name suffix
#   DEV   device type: GP307 | GP350 | MM200 | MX200 | CC10
#   PORT  asyn octet port name
#   ADDR  asyn address (0 for RS-232)
#   STN   station/user parameter (device-specific; empty or "0" when unused)
record(vs, "$(P)$(GAUGE)") {
    field(SCAN, "2 second")
    field(DTYP, "asyn VacSen")
    field(TYPE, "$(DEV)")
    field(INP,  "@asyn($(PORT) $(ADDR))$(STN)")
}
